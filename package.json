    "post-quantum",
    "pqc",
    "ml-dsa",
    "dilithium",
    "nist",
    "fips-204",
    "webhook",
    "webhook-signing",
    "webhook-verification",
    "hmac",
    "express",
    "fastify",
    "hono",
    "cloudflare-workers",
    "vercel",
    "kxco-post-quantum",
    "request-signing",
    "api-security",
    "key-rotation",
    "non-repudiation",
    "middleware",
    "edge-runtime",
    "bun",
    "deno"
  ],
  "license": "Apache-2.0",
  "author": "Shayne Heffernan and John Heffernan",
  "contributors": [
    {
      "name": "Shayne Heffernan"
    },
    {
      "name": "John Heffernan"
    }
  ],
  "homepage": "https://kxco.ai",
  "funding": "https://kxco.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/JackKXCO/kxco-post-quantum-webhook.git"
  },
