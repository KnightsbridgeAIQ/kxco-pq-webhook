    },
    "./builders": {
      "types": "./src/builders.d.ts",
      "import": "./src/builders.js"
    },
    "./client": {
      "types": "./src/client.d.ts",
      "import": "./src/client.js"
    },
    "./response-core": {
      "types": "./src/response-core.d.ts",
      "import": "./src/response-core.js"
    },
